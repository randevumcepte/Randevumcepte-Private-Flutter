platform :ios, '14.0'  # Burayı '12.0' yapmalısınız

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  # Firebase sürümünü sabitle (firebase_messaging uyumu için)
  pod 'Firebase/Messaging', '11.15.0'
  pod 'OneSignalXCFramework', '5.2.14'
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|	
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |build_configuration|
      build_configuration.build_settings['IPHONES_DEPLOYMENT_TARGET'] = '14.0'
      build_configuration.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      build_configuration.build_settings['SWIFT_COMPILATION_MODE'] = 'incremental'
      build_configuration.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
      
      # dSYM dosyaları için eklememiz gerekenler:
      build_configuration.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
      build_configuration.build_settings['ENABLE_BITCODE'] = 'NO'
      build_configuration.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1'
      ]
    end
  end
  pod 'GoogleWebRTC', :podspec => 'https://raw.githubusercontent.com/CocoaPods/Specs/master/Specs/7/e/b/GoogleWebRTC/1.1.31999/GoogleWebRTC.podspec.json'
end

